# ─────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────
# Public anon key — safe for browser/widget (read-only RLS-protected)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────
# Resend (email delivery)
# ─────────────────────────────────────────────
RESEND_API_KEY=re_your_api_key

# The "from" address used for all outgoing emails (must be verified in Resend)
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=ConversionCRM

# ─────────────────────────────────────────────
# Lemon Squeezy (subscriptions & billing)
# ─────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=your_api_key
LEMONSQUEEZY_STORE_ID=your_store_id
LEMONSQUEEZY_WEBHOOK_SECRET=your_webhook_signing_secret

# Variant IDs for each plan (find in LS dashboard)
LEMONSQUEEZY_VARIANT_STARTER=12345
LEMONSQUEEZY_VARIANT_PRO=67890

# ─────────────────────────────────────────────
# Cron security
# ─────────────────────────────────────────────
# A long random secret used to authenticate /api/cron/* calls
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ─────────────────────────────────────────────
# Widget / Event ingestion
# ─────────────────────────────────────────────
# Public base URL of this app, used to construct widget script URLs
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# ─────────────────────────────────────────────
# App internals
# ─────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NODE_ENV=development
