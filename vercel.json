{
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/score",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/emails",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/summary",
      "schedule": "0 8 * * *"
    }
  ]
}
